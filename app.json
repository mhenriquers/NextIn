{
  "expo": {
    "name": "nextin",
    "slug": "nextin",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/log.png",
    "scheme": "virtualstack",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/log.png",
        "backgroundImage": "./assets/images/log.png",
        "monochromeImage": "./assets/images/log.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/logoNext.png"
    },
    "splash": {
      "image": "./assets/images/log.png",
      "imageWidth": 200,
      "resizeMode": "contain",
      "backgroundColor": "#ffffff",
      "dark": {
        "backgroundColor": "#000000"
      }
    },
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    }
  }
}